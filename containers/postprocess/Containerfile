# BESS Post-Processing Container
# Tools for trajectory evaluation, point cloud export, and QC
#
# Includes:
#   - evo: Trajectory evaluation (ATE, RPE, plotting)
#   - pointcloudset: MCAP to LAS/CSV export
#   - Open3D: Point cloud processing and meshing
#   - laspy: LAS file I/O
#   - CloudCompare CLI: Point cloud comparison

FROM docker.io/ros:humble-ros-base

LABEL maintainer="BESS Team"
LABEL description="Post-processing tools for mobile mapping QC"

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-pip \
    python3-dev \
    python3-numpy \
    python3-scipy \
    python3-matplotlib \
    libgl1-mesa-glx \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    git \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Install ROS2 dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    ros-humble-rosbag2-storage-mcap \
    ros-humble-tf2-tools \
    ros-humble-tf-transformations \
    && rm -rf /var/lib/apt/lists/*

# Install Python tools
RUN pip3 install --no-cache-dir \
    evo \
    pointcloudset \
    open3d \
    laspy[laszip] \
    pandas \
    transforms3d \
    pyproj \
    pyyaml \
    tqdm \
    mcap \
    mcap-ros2-support \
    rosbags \
    kappe \
    pyarrow \
    duckdb \
    "py3dtiles[las]"

# Install PDAL — use apt PDAL 2.3 (Ubuntu 22.04) + compatible Python bindings
RUN apt-get update && apt-get install -y --no-install-recommends \
    pdal libpdal-dev libpdal-plugins \
    && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir --upgrade pip packaging && \
    pip3 install --no-cache-dir "pdal==3.2.3"  || \
    pip3 install --no-cache-dir "pdal==3.0.4"  || \
    echo "WARNING: PDAL Python bindings not installed — use pdal CLI instead"

# Build PotreeConverter
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-all-dev libtbb-dev cmake \
    && rm -rf /var/lib/apt/lists/* \
    && git clone --depth 1 https://github.com/potree/PotreeConverter.git /tmp/potree \
    && cd /tmp/potree && mkdir build && cd build \
    && cmake .. -DCMAKE_BUILD_TYPE=Release && make -j$(nproc) \
    && cp PotreeConverter /usr/local/bin/ \
    && rm -rf /tmp/potree

# Create workspace
WORKDIR /workspace

# Copy helper scripts
COPY scripts/ /workspace/scripts/
RUN chmod +x /workspace/scripts/*.py /workspace/scripts/*.sh 2>/dev/null || true

# Entry point
ENTRYPOINT ["/bin/bash"]
