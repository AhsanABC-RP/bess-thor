{
  "glim_ros": {
    "enable_local_mapping": true,
    "enable_global_mapping": true,
    "keep_raw_points": true,

    "imu_time_offset": 0.0,
    "points_time_offset": 0.0,
    "acc_scale": 1.0,

    "imu_frame_id": "imu_link",
    "lidar_frame_id": "os_lidar",
    "base_frame_id": "base_link",
    "odom_frame_id": "odom",
    "map_frame_id": "map",
    "publish_imu2lidar": false,
    "tf_time_offset": 1e-6,

    "extension_modules": [],

    "imu_topic": "/imu/data",
    "points_topic": "/ouster/points",
    "image_topic": "/image",

    "imu_qos": { "profile": "sensor_data", "depth": 1000 },
    "points_qos": { "profile": "sensor_data" },
    "image_qos": { "profile": "sensor_data" }
  }
}
