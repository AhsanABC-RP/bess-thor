{
  "glim_ros": {
    "enable_local_mapping": true,
    "enable_global_mapping": false,
    "keep_raw_points": false,

    "imu_time_offset": 0.0,
    "points_time_offset": 0.0,
    "acc_scale": 1.0,

    "imu_frame_id": "os_imu",
    "lidar_frame_id": "os_lidar",
    "base_frame_id": "glim_base_link",
    "odom_frame_id": "glim_odom",
    "map_frame_id": "glim_map",
    "publish_imu2lidar": false,
    "tf_time_offset": 1e-6,

    "extension_modules": ["librviz_viewer.so"],

    "imu_topic": "/ouster/imu_guarded",
    "points_topic": "/ouster/points",
    "image_topic": "/image",

    "imu_qos": { "profile": "sensor_data", "depth": 5000 },
    "points_qos": { "profile": "sensor_data", "depth": 50 },
    "image_qos": { "profile": "sensor_data" }
  }
}
